{
  "meta": {
    "id": "shaper_data_shaper_aggressive",
    "title": "Shaper: Data Shaper (aggressive)",
    "category": "shaper",
    "profile": "aggressive",
    "description": [
      "Shaper: Data Shaper (aggressive) replays live-power input through the current shaper rather than solar-divert control.",
      "More responsive shaping profile. Look for quicker tracking of available power and potentially more frequent adjustments.",
      "Compare live power, smoothed live power, shaper maximum, available charge power, and actual charge power to see how the limiter reacts.",
      "Duration: 2 hours."
    ]
  },
  "simulation": {
    "duration": 7200,
    "tick_interval": 1,
    "start_time": "2023-12-17T13:25:00Z"
  },
  "config": {
    "current_shaper_smoothing_time": 30,
    "current_shaper_min_pause_time": 60,
    "current_shaper_max_pwr": 3000
  },
  "peers": [
    {
      "id": "evse-001",
      "voltage": 240,
      "min_current": 6,
      "max_current": 32,
      "ev": {
        "battery_capacity_kwh": 100,
        "initial_soc": 10,
        "max_charge_rate_kw": 7.2
      },
      "initial": {
        "online": true,
        "vehicle": true
      },
      "inputs": {
        "live_pwr": {
          "csv": "../data_shaper.csv",
          "time_column": 0,
          "column": 1,
          "skip_header": true,
          "separator": ";"
        }
      }
    }
  ],
  "config_include": "config-shaper-default.json"
}
