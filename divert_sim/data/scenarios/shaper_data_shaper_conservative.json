{
  "meta": {
    "id": "shaper_data_shaper_conservative",
    "title": "Shaper: Data Shaper (conservative)",
    "category": "shaper",
    "profile": "conservative",
    "description": [
      "Shaper: Data Shaper (conservative) replays live-power input through the current shaper rather than solar-divert control.",
      "More cautious shaping profile. Look for slower ramping and less aggressive use of short power headroom changes.",
      "Compare live power, smoothed live power, shaper maximum, available charge power, and actual charge power to see how the limiter reacts.",
      "Duration: 2 hours."
    ]
  },
  "simulation": {
    "duration": 7200,
    "tick_interval": 1,
    "start_time": "2023-12-17T13:25:00Z"
  },
  "config": {
    "current_shaper_smoothing_time": 120,
    "current_shaper_min_pause_time": 600,
    "current_shaper_max_pwr": 8000
  },
  "peers": [
    {
      "id": "evse-001",
      "voltage": 240,
      "min_current": 6,
      "max_current": 32,
      "ev": {
        "battery_capacity_kwh": 100,
        "initial_soc": 10,
        "max_charge_rate_kw": 7.2
      },
      "initial": {
        "online": true,
        "vehicle": true
      },
      "inputs": {
        "live_pwr": {
          "csv": "../data_shaper.csv",
          "time_column": 0,
          "column": 1,
          "skip_header": true,
          "separator": ";"
        }
      }
    }
  ],
  "config_include": "config-shaper-default.json"
}
